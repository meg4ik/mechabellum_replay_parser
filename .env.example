# ── Docker core ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
PLAYER_NAME=YourNameHere
OPENAI_MODEL=gpt-4o
DEBUG=false

DATABASE_URL=postgresql+psycopg://mechabellum:mechabellum@postgres:5432/mechabellum
REDIS_URL=redis://redis:6379/0

# Path inside Docker container where replays are mounted
REPLAY_DIR=/data/replays
KNOWLEDGE_PATH=/app/game_knowledge.md

# What to do with .grbr after processing: delete | archive | keep
REPLAY_AFTER_PROCESS=archive

# ── Host machine (Docker Compose volume source) ───────────────────────────────
# Windows default; change if Steam is installed elsewhere or use a symlink
MECHABELLUM_REPLAY_DIR=C:\Program Files (x86)\Steam\steamapps\common\Mechabellum\ProjectDatas\Replay

# ── Native UI (run on host, not inside Docker) ────────────────────────────────
CORE_API_URL=http://localhost:8000
CORE_WS_URL=ws://localhost:8000/events/ws
